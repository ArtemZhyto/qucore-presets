|-------------------------|
|		   CONFIGURATION      |
|-------------------------|

# Service ports
<SERVICE_NAME>_SERVICE=5000

# PostgreSQL
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=authdb
POSTGRES_PORT=5001

# PostgreSQL connection string
DATABASE_URL=postgres://myuser:mypassword@postgres:5432/authdb

# Redis
REDIS_PORT=5000
REDIS_URL=redis://redis:6379



|-------------------------|
|		      SECRETS         |
|-------------------------|

COOKIES_SECRET=mycookies